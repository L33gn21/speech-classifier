    modified_response: "\355\225\264\354\273\244\355\206\244\354\232\251 \354\230\201\354\226\264 \354\226\265\354\226\221 \353\266\204\354\204\235 \354\213\234\354\212\244\355\205\234(AccentLens)\354\235\230 \355\224\204\353\241\234\355\206\240\355\203\200\354\236\205 \352\265\254\355\230\204\354\235\204 \354\231\204\353\243\214\355\226\210\354\212\265\353\213\210\353\213\244! \354\232\224\352\265\254\354\202\254\355\225\255\354\227\220 \353\247\236\354\266\260 \352\261\260\354\260\275\355\225\234 \353\224\245\353\237\254\353\213\235 \354\213\234\354\212\244\355\205\234\354\235\204 \354\262\230\354\235\214\353\266\200\355\204\260 \353\247\214\353\223\244\354\247\200 \354\225\212\352\263\240, `librosa`\353\241\234 \354\230\244\353\224\224\354\230\244\354\235\230 MFCC(\354\243\274\355\214\214\354\210\230 \355\212\271\354\204\261)\353\245\274 \354\266\224\354\266\234\355\225\234 \353\222\244 `scikit-learn`\354\235\230 \352\260\200\353\262\274\354\232\264 \353\250\270\354\213\240\353\237\254\353\213\235(\353\236\234\353\215\244 \355\217\254\353\240\210\354\212\244\355\212\270) \353\252\250\353\215\270\353\241\234 \353\266\204\353\245\230\355\225\230\353\212\224 \354\213\244\354\232\251\354\240\201\354\235\264\352\263\240 \353\271\240\353\245\270 \353\260\251\354\213\235\354\235\204 \354\261\204\355\203\235\355\226\210\354\212\265\353\213\210\353\213\244. \n\n\353\213\244\354\235\214 \355\214\214\354\235\274\353\223\244\354\235\204 \354\203\235\354\204\261\355\225\264 \353\221\220\354\227\210\354\212\265\353\213\210\353\213\244:\n\n1. **`app.py`**: Streamlit\354\234\274\353\241\234 \353\247\214\353\223\240 \354\233\271 UI \354\225\261\354\236\205\353\213\210\353\213\244. \354\226\265\354\226\221 \353\266\204\354\204\235, \353\252\250\353\215\270 \355\225\231\354\212\265, \354\233\220\353\246\254 \354\204\244\353\252\205(About) \355\203\255\354\234\274\353\241\234 \352\265\254\354\204\261\353\220\230\354\226\264 \354\236\210\354\212\265\353\213\210\353\213\244.\n2. **`audio_utils.py`**: \354\230\244\353\224\224\354\230\244 \354\240\204\354\262\230\353\246\254 \353\252\250\353\223\210 (\353\252\250\353\205\270 \353\263\200\355\231\230, 16kHz \353\246\254\354\203\230\355\224\214\353\247\201, \353\254\264\354\235\214 \354\240\234\352\261\260, \353\263\274\353\245\250 \354\240\225\352\267\234\355\231\224 \354\262\230\353\246\254).\n3. **`feature_extractor.py`**: \354\230\244\353\224\224\354\230\244 \353\215\260\354\235\264\355\204\260\354\227\220\354\204\234 MFCC \355\212\271\354\247\225\354\235\204 \354\266\224\354\266\234\355\225\230\352\263\240, \354\213\234\352\260\204\354\266\225 \352\270\260\354\244\200\354\235\230 \355\217\211\352\267\240\352\263\274 \355\221\234\354\244\200\355\216\270\354\260\250\353\245\274 \352\265\254\355\225\230\354\227\254 \352\263\240\354\240\225 \352\270\270\354\235\264\354\235\230 \353\262\241\355\204\260\353\241\234 \353\260\230\355\231\230\355\225\230\353\212\224 \353\252\250\353\223\210\354\236\205\353\213\210\353\213\244.\n4. **`train_model.py`**: `dataset/` \355\217\264\353\215\224 \353\202\264\354\235\230 \354\230\244\353\224\224\354\230\244 \355\214\214\354\235\274\353\223\244\354\235\204 \354\212\244\354\272\224\355\225\264 \353\252\250\353\215\270\354\235\204 \355\225\231\354\212\265\354\213\234\355\202\244\352\263\240 `models/accent_classifier.joblib`\353\241\234 \354\240\200\354\236\245\355\225\230\353\212\224 \354\212\244\355\201\254\353\246\275\355\212\270\354\236\205\353\213\210\353\213\244.\n5. **`predict.py`**: \354\240\200\354\236\245\353\220\234 \353\252\250\353\215\270\354\235\204 \353\266\210\353\237\254\354\231\200\354\204\234 \354\203\210\353\241\234\354\232\264 \354\230\244\353\224\224\354\230\244 \355\214\214\354\235\274\354\235\230 \354\226\265\354\226\221 \354\234\240\354\202\254\353\217\204\353\245\274 \355\231\225\353\245\240(%)\353\241\234 \354\230\210\354\270\241\355\225\251\353\213\210\353\213\244.\n6. **`requirements.txt`**: \355\214\214\354\235\264\354\215\254 \355\214\250\355\202\244\354\247\200 \354\235\230\354\241\264\354\204\261 \353\252\251\353\241\235\354\236\205\353\213\210\353\213\244.\n7. **`README.md` & `dataset/README.md`**: \354\213\244\355\226\211 \353\260\251\353\262\225\352\263\274 \355\224\204\353\241\234\354\240\235\355\212\270 \352\260\234\354\232\224, \352\265\220\354\210\230\353\213\230\352\273\230 \354\204\244\353\252\205\355\225\240 \354\210\230 \354\236\210\353\212\224 \354\230\201\353\254\270 \352\260\234\354\232\224\352\260\200 \354\240\201\355\230\200\354\236\210\354\212\265\353\213\210\353\213\244.\n\n\354\235\264 \355\224\204\353\241\234\354\240\235\355\212\270\353\212\224 \353\263\204\353\217\204\354\235\230 \354\231\270\353\266\200 \354\204\234\353\262\204\353\202\230 API \355\230\270\354\266\234 \354\227\206\354\235\264(API \355\202\244 \353\266\210\355\225\204\354\232\224), \353\241\234\354\273\254\354\227\220 \354\236\210\353\212\224 \353\215\260\354\235\264\355\204\260\353\245\274 \355\206\265\355\225\264\354\204\234\353\247\214 \353\266\204\354\204\235\354\235\204 \354\210\230\355\226\211\355\225\230\354\227\254 \353\263\264\354\225\210 \353\260\217 \352\260\234\354\235\270\354\240\225\353\263\264 \353\254\270\354\240\234\353\217\204 \352\271\224\353\201\224\355\225\230\352\262\214 \355\225\264\352\262\260\353\220\251\353\213\210\353\213\244. \354\225\261 \355\231\224\353\251\264\354\227\220\353\212\224 \"\352\265\255\354\240\201\354\235\204 \355\214\220\353\263\204\355\225\230\353\212\224 \352\262\203\354\235\264 \354\225\204\353\213\210\353\235\274, \353\260\234\354\235\214 \355\214\250\355\204\264\354\235\264 \354\226\264\353\226\244 \354\226\265\354\226\221 \352\267\270\353\243\271\354\227\220 \352\260\200\354\236\245 \352\260\200\352\271\214\354\232\264\354\247\200 \353\266\204\354\204\235\355\225\234\353\213\244\"\353\212\224 \354\243\274\354\235\230\354\202\254\355\225\255(Disclaimer)\354\235\204 \353\252\205\355\231\225\355\236\210 \352\270\260\354\236\254\355\225\264 \353\221\220\354\227\210\354\212\265\353\213\210\353\213\244. \n\n**\353\241\234\354\273\254\354\227\220\354\204\234 \354\213\244\355\226\211\355\225\230\353\212\224 \353\260\251\353\262\225**:\n\354\242\214\354\270\241 \355\214\214\354\235\274 \355\214\250\353\204\220\354\227\220\354\204\234 \354\236\221\354\204\261\353\220\234 \354\275\224\353\223\234\353\223\244\354\235\204 \353\213\244\354\232\264\353\241\234\353\223\234 \355\225\230\354\213\240 \355\233\204, \355\204\260\353\257\270\353\204\220\354\227\220\354\204\234 \353\213\244\354\235\214 \353\252\205\353\240\271\354\226\264\353\245\274 \354\213\244\355\226\211\355\225\230\354\227\254 \353\260\224\353\241\234 \355\205\214\354\212\244\355\212\270\355\225\264\353\263\264\354\213\244 \354\210\230 \354\236\210\354\212\265\353\213\210\353\213\244!\n```bash\n# 1. \355\214\250\355\202\244\354\247\200 \354\204\244\354\271\230\npip install -r requirements.txt\n\n# 2. \353\215\260\354\235\264\355\204\260\354\205\213 \355\217\264\353\215\224 \353\247\214\353\223\244\352\263\240 \354\203\230\355\224\214 \354\230\244\353\224\224\354\230\244 \353\204\243\352\270\260 (dataset/Korean-accented English/ \353\223\261)\n# 3. \353\252\250\353\215\270 \355\225\231\354\212\265 (UI\354\227\220\354\204\234\353\217\204 \352\260\200\353\212\245)\npython train_model.py\n\n# 4. Streamlit \354\233\271 \354\225\261 \354\213\244\355\226\211\nstreamlit run app.py\n```\n\n\354\204\261\352\263\265\354\240\201\354\235\270 \355\225\264\354\273\244\355\206\244 \353\220\230\354\213\234\352\270\270 \353\260\224\353\236\215\353\213\210\353\213\244! \355\225\204\354\232\224\355\225\234 \354\210\230\354\240\225\354\202\254\355\225\255\354\235\264 \354\236\210\353\213\244\353\251\264 \354\226\270\354\240\234\353\223\240 \353\247\220\354\224\200\355\225\264 \354\243\274\354\204\270\354\232\224."
