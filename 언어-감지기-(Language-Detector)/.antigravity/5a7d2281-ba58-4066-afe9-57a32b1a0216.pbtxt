          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "- The system should be used for education or pronunciation feedback, not discrimination."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
