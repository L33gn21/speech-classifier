          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "## Ethics Disclaimer"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "- Accent does not perfectly represent nationality."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
