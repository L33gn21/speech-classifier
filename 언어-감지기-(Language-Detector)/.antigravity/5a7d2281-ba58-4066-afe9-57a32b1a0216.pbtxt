          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        classes = self.le.classes_"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        # Create a sorted list of (class_name, probability)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        results = [(classes[i], probas[i]) for i in range(len(classes))]"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        results.sort(key=lambda x: x[1], reverse=True)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
